# Application
APP_NAME=go-api-kit
APP_ENV=development
APP_VERSION=2.0.0

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# Database — PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=mydb
DB_SSLMODE=disable

# Convenience URL used by goose CLI and scripts/migrate.sh
DATABASE_URL=postgres://postgres:secret@localhost:5432/mydb?sslmode=disable

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
